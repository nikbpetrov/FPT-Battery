{
  "name": "@nikbpetrov/fpt-battery-test",
  "version": "0.1.0",
  "description": "Forecasting Proficiency Test - A jspsych-based experiment battery",
  "type": "module",
  "main": "./dist/fpt-battery.umd.js",
  "module": "./dist/fpt-battery.es.js",
  "exports": {
    ".": {
      "import": "./dist/fpt-battery.es.js",
      "require": "./dist/fpt-battery.umd.js"
    },
    "./css": "./dist/fpt-battery.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "ln -sfn ../src demo/src 2>/dev/null; vite --host",
    "dev:build": "vite build --watch",
    "build": "vite build",
    "build:copy": "vite build && cp -r dist/* ../../static/dist/",
    "preview": "vite preview"
  },
  "dependencies": {
    "@jspsych/plugin-browser-check": "^1.0.3",
    "@jspsych/plugin-call-function": "^1.1.3",
    "@jspsych/plugin-html-button-response": "^1.1.3",
    "@jspsych/plugin-html-keyboard-response": "^1.1.3",
    "@jspsych/plugin-html-slider-response": "^1.1.3",
    "@jspsych/plugin-instructions": "^1.1.4",
    "@jspsych/plugin-survey-html-form": "^1.0.3",
    "@jspsych/plugin-survey-multi-choice": "^1.1.3",
    "@jspsych/plugin-survey-multi-select": "^1.1.3",
    "@jspsych/plugin-survey-text": "^1.1.3",
    "chart.js": "^4.5.1",
    "jspsych": "^7.3.4"
  },
  "devDependencies": {
    "vite": "^5.4.0"
  },
  "keywords": [
    "jspsych",
    "forecasting",
    "psychology",
    "experiment"
  ],
  "license": "MIT"
}
